{
    "control": {
        "Package": "clandro-exec",
        "Version": "@CLANDRO_EXEC_PKG__VERSION@",
        "Architecture": "@CLANDRO_EXEC_PKG__ARCH@",
        "Maintainer": "@clandro",
        "Homepage": "https://github.com/cl-andro/clandro-exec-package",
        "Description": "Utils and libraries for Clandro exec including a LD_PRELOAD shared library for proper functioning of the Clandro execution environment"
    },

    "installation_prefix": "@CLANDRO__PREFIX@",
    "control_files_dir": "build/output/packaging/debian",

    "data_files": {
        "": {
            "source": "build/output/usr",
            "source_recurse": true
        }
    }
}
