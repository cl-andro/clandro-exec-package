#!@CLANDRO__PREFIX@/bin/bash
# shellcheck shell=bash

##
# `libclandro_exec__nos__c__tests__main`
##
libclandro_exec__nos__c__tests__main() {

    CLANDRO_EXEC__TESTS__LOG_TAG="lib@CLANDRO__LNAME@-exec_c.tests"

    clandro_exec__tests__log 4 "main()"

    # Set `CLANDRO_EXEC__TESTS__TESTS_PATH` used by compiled c tests.
    if [[ ! "$CLANDRO_EXEC__TESTS__TESTS_PATH" =~ $CLANDRO_EXEC__TESTS__REGEX__ROOTFS_OR_ABSOLUTE_PATH ]]; then
        clandro_exec__tests__log_error "The CLANDRO_EXEC__TESTS__TESTS_PATH '$CLANDRO_EXEC__TESTS__TESTS_PATH' is either not set or is not an absolute path"
        return 1
    fi


    # Run unit tests.
    if [[ "$CLANDRO_EXEC__TESTS__RUN_UNIT_TESTS" == "true" ]]; then
        libclandro_exec__nos__c__unit_tests__run_command || return $?
    fi

    # Run runtime tests.
    if [[ "$CLANDRO_EXEC__TESTS__RUN_RUNTIME_TESTS" == "true" ]]; then
        libclandro_exec__nos__c__runtime_tests__run_command || return $?
    fi

    return 0

}



##
# `libclandro_exec__nos__c__unit_tests__run_command`
##
libclandro_exec__nos__c__unit_tests__run_command() {

    local return_value

    clandro_exec__tests__log 4 "Running 'unit' tests"

    (
        libclandro_exec__nos__c__unit_binary_tests__run_command || exit $?
    ) || return $?

    return 0

}

##
# `libclandro_exec__nos__c__unit_binary_tests__run_command`
##
libclandro_exec__nos__c__unit_binary_tests__run_command() {

    local return_value

    local tests_start_time; tests_start_time="$(date "+%s")" || return $?

    local unit_binary_tests_variant="unit-binary-tests"

    if [[ "$CLANDRO_EXEC__TESTS__USE_FSANITIZE_BUILDS" == "true" ]]; then
        unit_binary_tests_variant+="-fsanitize"
    else
        unit_binary_tests_variant+="-nofsanitize"
    fi

    clandro_exec__tests__log 1 "Running 'libclandro-exec_nos_c_tre_${unit_binary_tests_variant}'"

    output="$(
        # cd first and execute with relative path to shorten `argv[0]`,
        # otherwise command will fail with exit code `1` on Android `< 6`
        # without any error if `argv[0]` length is `>= 128`.
        # Check `checkExecArg0BufferOverflow()` function in `ExecIntercept.h`.
        cd "$CLANDRO_EXEC__TESTS__TESTS_PATH/lib/clandro-exec_nos_c/tre/bin" || exit $?
        printf -v "$CLANDRO_EXEC__TESTS__LOG_LEVEL___N" "%s" "$CLANDRO_EXEC__TESTS__LOG_LEVEL" || exit $?
        export "${CLANDRO_EXEC__TESTS__LOG_LEVEL___N?}" || exit $?
        export LD_PRELOAD="$CLANDRO_EXEC__TESTS__PRIMARY_LD_PRELOAD_FILE_PATH" || exit $?
        ASAN_OPTIONS="fast_unwind_on_malloc=false:detect_leaks=$CLANDRO_EXEC__TESTS__DETECT_LEAKS" LSAN_OPTIONS="report_objects=$CLANDRO_EXEC__TESTS__DETECT_LEAKS" \
            "./libclandro-exec_nos_c_tre_${unit_binary_tests_variant}" 2>&1)"
    return_value=$?
    if [ $return_value -eq 0 ] ||
        { [ $return_value -eq 141 ] &&
            { [[ "$output" == *"WARNING: Can't read from symbolizer at fd"* ]] ||
              [[ "$output" == *"WARNING: external symbolizer didn't start up correctly!"* ]]
            } &&
            [[ "$output" == *"runTests(end)"* ]];
        }; then
        printf "%s\n" "$output"
    else
        printf "%s\n" "$output" 1>&2
        clandro_exec__tests__log_error "'libclandro-exec_nos_c_tre_${unit_binary_tests_variant}' failed"
        return $return_value
    fi

    clandro_exec__tests__log 2 "'libclandro-exec_nos_c_tre_${unit_binary_tests_variant}' completed in \
$(clandro_exec__tests__print_elapsed_time "$tests_start_time")"

    return 0

}



##
# `libclandro_exec__nos__c__runtime_tests__run_command`
##
libclandro_exec__nos__c__runtime_tests__run_command() {

    local return_value

    clandro_exec__tests__log 4 "Running 'runtime' tests"

    (
        libclandro_exec__nos__c__runtime_binary_tests__run_command || return $? || exit $?
    ) || return $?

    (
        libclandro_exec__nos__c__runtime_script_tests__run_command || return $? || exit $?
    ) || return $?

    return 0

}

##
# `libclandro_exec__nos__c__runtime_binary_tests__run_command`
##
libclandro_exec__nos__c__runtime_binary_tests__run_command() {

    local return_value

    local tests_start_time; tests_start_time="$(date "+%s")" || return $?

    local runtime_binary_tests_variant="runtime-binary-tests"

    if [[ "$CLANDRO_EXEC__TESTS__USE_FSANITIZE_BUILDS" == "true" ]]; then
        runtime_binary_tests_variant+="-fsanitize"
    else
        runtime_binary_tests_variant+="-nofsanitize"
    fi

    if [ "$ANDROID__BUILD_VERSION_SDK" -ge 28 ] && \
            [ -f "$CLANDRO_EXEC__TESTS__TESTS_PATH/lib/clandro-exec_nos_c/tre/bin/libclandro-exec_nos_c_tre_${runtime_binary_tests_variant}28" ]; then
        runtime_binary_tests_variant+="28"
    fi

    clandro_exec__tests__log 1 "Running 'libclandro-exec_nos_c_tre_${runtime_binary_tests_variant}'"
    (
        # cd first and execute with relative path to shorten `argv[0]`,
        # otherwise command will fail with exit code `1` on Android `< 6`
        # without any error if `argv[0]` length is `>= 128`.
        # Check `checkExecArg0BufferOverflow()` function in `ExecIntercept.h`.
        cd "$CLANDRO_EXEC__TESTS__TESTS_PATH/lib/clandro-exec_nos_c/tre/bin" || exit $?
        printf -v "$CLANDRO_EXEC__TESTS__LOG_LEVEL___N" "%s" "$CLANDRO_EXEC__TESTS__LOG_LEVEL" || exit $?
        export "${CLANDRO_EXEC__TESTS__LOG_LEVEL___N?}" || exit $?
        ASAN_OPTIONS="fast_unwind_on_malloc=false:detect_leaks=$CLANDRO_EXEC__TESTS__DETECT_LEAKS" LSAN_OPTIONS="report_objects=$CLANDRO_EXEC__TESTS__DETECT_LEAKS" \
            "./libclandro-exec_nos_c_tre_${runtime_binary_tests_variant}"
    )
    return_value=$?
    if [ $return_value -ne 0 ]; then
        clandro_exec__tests__log_error "'libclandro-exec_nos_c_tre_${runtime_binary_tests_variant}' failed"
        return $return_value
    fi

    clandro_exec__tests__log 2 "'libclandro-exec_nos_c_tre_${runtime_binary_tests_variant}' completed in \
$(clandro_exec__tests__print_elapsed_time "$tests_start_time")"

}

##
# `libclandro_exec__nos__c__runtime_script_tests__run_command`
##
libclandro_exec__nos__c__runtime_script_tests__run_command() {

    local return_value

    local tests_start_time; tests_start_time="$(date "+%s")" || return $?

    clandro_exec__tests__log 1 "Running 'libclandro-exec_nos_c_tre_runtime-script-tests'"

    (
        # shellcheck source=lib/clandro-exec_nos_c/tre/tests/scripts/libclandro-exec_nos_c_tre_runtime-script-tests.in
        clandro_exec__tests__source_file_from_path \
            "$CLANDRO_EXEC__TESTS__TESTS_PATH/lib/clandro-exec_nos_c/tre/scripts/libclandro-exec_nos_c_tre_runtime-script-tests" || exit $?

        libclandro_exec__nos__c__runtime_script_tests__main
    )
    return_value=$?
    if [ $return_value -ne 0 ]; then
        clandro_exec__tests__log_error "'libclandro-exec_nos_c_tre_runtime-script-tests' failed"
        return $return_value
    fi

    clandro_exec__tests__log 2 "'libclandro-exec_nos_c_tre_runtime-script-tests' completed in \
$(clandro_exec__tests__print_elapsed_time "$tests_start_time")"

    return 0

}
