#!@CLANDRO__PREFIX@/bin/sh
# shellcheck shell=sh
# shellcheck disable=SC2039,SC2059,SC3043

clandro_exec__ld_preload_lib__init() {

CLANDRO_EXEC__LD_PRELOAD_LIB__LOG_LEVEL___N="@CLANDRO_ENV__S_CLANDRO_EXEC@LD_PRELOAD_LIB__LOG_LEVEL"
clandro_exec__ld_preload_lib__copy_variable CLANDRO_EXEC__LD_PRELOAD_LIB__LOG_LEVEL "$CLANDRO_EXEC__LD_PRELOAD_LIB__LOG_LEVEL___N" || return $?
case "${CLANDRO_EXEC__LD_PRELOAD_LIB__LOG_LEVEL:-}" in
    0|1|2) :;; *) CLANDRO_EXEC__LD_PRELOAD_LIB__LOG_LEVEL=1;; # Default: `1` (OFF=0, NORMAL=1, DEBUG=2)
esac

CLANDRO_EXEC__SYSTEM_LINKER_EXEC__LOG_LEVEL___N="@CLANDRO_ENV__S_CLANDRO_EXEC@SYSTEM_LINKER_EXEC__LOG_LEVEL"

CLANDRO__PREFIX___N="@CLANDRO_ENV__S_CLANDRO@PREFIX"
clandro_exec__ld_preload_lib__copy_variable CLANDRO__PREFIX "$CLANDRO__PREFIX___N" || return $?
case "${CLANDRO__PREFIX:-}" in
    /*[!/]) :;; *) CLANDRO__PREFIX="@CLANDRO__PREFIX@";;
esac

}



clandro_exec__ld_preload_lib__log() { local log_level="${1}"; shift; if [ "$CLANDRO_EXEC__LD_PRELOAD_LIB__LOG_LEVEL" -ge "$log_level" ]; then echo "@CLANDRO__LNAME@-exec:" "$@"; fi }
clandro_exec__ld_preload_lib__log_error() { echo "@CLANDRO__LNAME@-exec:" "$@" 1>&2; }



##
# `clandro_exec__ld_preload_lib__main` [`<argument...>`]
##
clandro_exec__ld_preload_lib__main() {

    clandro_exec__ld_preload_lib__init || return $?


    if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
        clandro_exec__ld_preload_lib__show_help || return $?
        return 0
    elif [ "${1:-}" = "--version" ]; then
        echo "clandro-exec-ld-preload-lib version=@CLANDRO_EXEC_PKG__VERSION@ org=@CLANDRO__REPOS_HOST_ORG_NAME@ project=clandro-exec-package"; return $?
        return 0
    fi


    local command_type="${1:-}"
    [ $# -gt 0 ] && shift 1

    if [ "$command_type" = "setup" ]; then
        if [ "${1:-}" = "-q" ] || [ "${1:-}" = "--quiet" ]; then
            CLANDRO_EXEC__LD_PRELOAD_LIB__LOG_LEVEL=0
            shift 1
        elif [ "${1:-}" = "-v" ]; then
            CLANDRO_EXEC__LD_PRELOAD_LIB__LOG_LEVEL=2
            shift 1
        fi
    else
        echo "The command '$command_type' passed to 'clandro-exec-ld-preload-lib' is not valid." 1>&2
        return 64 # EX__USAGE
    fi


    clandro_exec__ld_preload_lib__set_variable "$CLANDRO_EXEC__SYSTEM_LINKER_EXEC__LOG_LEVEL___N" "$CLANDRO_EXEC__LD_PRELOAD_LIB__LOG_LEVEL" || return $?
    export "${CLANDRO_EXEC__SYSTEM_LINKER_EXEC__LOG_LEVEL___N?}" || return $?


    if [ "$command_type" = "setup" ]; then
        clandro_exec__ld_preload_lib__setup__run_command setup || return $?
    fi

    return 0

}



##
# `clandro_exec__ld_preload_lib__setup__run_command`
##
clandro_exec__ld_preload_lib__setup__run_command() {

    local system_linker_exec_enabled

    system_linker_exec_enabled="$(clandro-exec-system-linker-exec is-enabled)" || return $?

    local ld_preload_file

    if [ "$system_linker_exec_enabled" != "true" ]; then
        ld_preload_file="$CLANDRO__PREFIX/lib/libclandro-exec-direct-ld-preload.so"
    else
        ld_preload_file="$CLANDRO__PREFIX/lib/libclandro-exec-linker-ld-preload.so"
    fi
    clandro_exec__ld_preload_lib__log 1 "Setting primary Clandro '\$LD_PRELOAD' library in 'libclandro-exec-ld-preload.so' to '$ld_preload_file'"

    mkdir -p "$CLANDRO__PREFIX/lib" || return $?

    # Prevent `Segmentation fault (SIGSEGV fault addr)` when running
    # commands in calling shell of the script after new file has been
    # copied below.
    rm -f "$CLANDRO__PREFIX/lib/libclandro-exec-ld-preload.so" || return $?

    # Prevent `CANNOT LINK EXECUTABLE "cp": library "/data/data/com.clandro/files/usr/lib/libclandro-exec-ld-preload.so" not found: needed by main executable`
    unset LD_PRELOAD || return $?

    cp -a "$ld_preload_file" "$CLANDRO__PREFIX/lib/libclandro-exec-ld-preload.so" || return $?

}



##
# `clandro_exec__ld_preload_lib__is_valid_shell_name` `<name>`
##
clandro_exec__ld_preload_lib__is_valid_shell_name() {

    if [ -z "${1:-}" ]; then
        return 1
    fi

    local name_rest="${1#?}" # 1:end
    local name_first_char="${1%"$name_rest"}" # 0:1
    case "$name_first_char" in
        [a-zA-Z_])
            case "$name_rest" in
                *[!a-zA-Z0-9_]*) return 1;;
                *) return 0;;
            esac;;
        *) return 1;;
    esac

}

##
# `clandro_exec__ld_preload_lib__set_variable` `<variable_name>` `<variable_value>`
##
clandro_exec__ld_preload_lib__set_variable() {

    local variable_name="${1:-}"
    local variable_value="${2:-}"

    if ! clandro_exec__ld_preload_lib__is_valid_shell_name "$variable_name"; then
        clandro_exec__ld_preload_lib__log_error "The variable_name '$variable_name' is not a valid shell variable name."
        return 64 # EX__USAGE
    fi

    eval "$variable_name"=\"\$variable_value\"

}

clandro_exec__ld_preload_lib__copy_variable() {

    local output_variable_name="${1:-}"
    local input_variable_name="${2:-}"

    if ! clandro_exec__ld_preload_lib__is_valid_shell_name "$output_variable_name"; then
        clandro_exec__ld_preload_lib__log_error "The output_variable_name '$output_variable_name' is not a valid shell variable name."
        return 1
    fi

    if ! clandro_exec__ld_preload_lib__is_valid_shell_name "$input_variable_name"; then
        clandro_exec__ld_preload_lib__log_error "The input_variable_name '$input_variable_name' is not a valid shell variable name."
        return 1
    fi

    eval "$output_variable_name"=\"\$\{"$input_variable_name":-\}\"

}



##
# `clandro_exec__ld_preload_lib__show_help`
##
clandro_exec__ld_preload_lib__show_help() {

    cat <<'HELP_EOF'
clandro-exec-ld-preload-lib can be used to manage Clandro '$LD_PRELOAD'
library.


Usage:
    clandro-exec-ld-preload-lib [command_options] <command>

Available commands:
    setup                     Setup the primary Clandro '$LD_PRELOAD'
                              library in 'libclandro-exec-ld-preload.so'
                              to direct or linker variant.

Available command_options:
    [ -h | --help ]           Display this help screen.
    [ --version ]             Display version.
    [ -q | --quiet ]          Set log level to 'OFF'.
    [ -v ]
                              Set log level to 'DEBUG'.
HELP_EOF

}



clandro_exec__ld_preload_lib__main "$@"
